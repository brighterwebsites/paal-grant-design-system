{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/awards/**",
              "components/badges/**",
              "components/buttons/**",
              "components/cards/**",
              "components/forms/**",
              "components/navigation/**",
              "components/reviews/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Raleway))/i]",
        "message": "Font not provided by the design system. Available: Raleway."
      },
      {
        "selector": "JSXOpeningElement[name.name='AwardPlaque'] > JSXAttribute > JSXIdentifier[name!=/^(?:motif|icon|category|name|subtitle|key|ref|className|style|children)$/]",
        "message": "<AwardPlaque> doesn't accept that prop. Declared props: motif, icon, category, name, subtitle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:section-label|award|size|tag|breadcrumb|gold-title|size-badge)$/]",
        "message": "<Badge> variant must be one of 'section-label' | 'award' | 'size' | 'tag' | 'breadcrumb' | 'gold-title' | 'size-badge'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|onClick|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, onClick, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:sage|ghost|nav-cta|pkg)$/]",
        "message": "<Button> variant must be one of 'sage' | 'ghost' | 'nav-cta' | 'pkg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|placeholder|options|value|onChange|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, type, placeholder, options, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|tel|textarea|select)$/]",
        "message": "<FormField> type must be one of 'text' | 'email' | 'tel' | 'textarea' | 'select'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nav'] > JSXAttribute > JSXIdentifier[name!=/^(?:currentPage|onNavigate|logoSrc|key|ref|className|style|children)$/]",
        "message": "<Nav> doesn't accept that prop. Declared props: currentPage, onNavigate, logoSrc."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nav'] > JSXAttribute[name.name='currentPage'] > Literal[value!=/^(?:home|about|process|packages|portfolio|contact)$/]",
        "message": "<Nav> currentPage must be one of 'home' | 'about' | 'process' | 'packages' | 'portfolio' | 'contact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|location|title|tall|minHeight|onClick|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: image, location, title, tall, minHeight, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|avatarColor|name|date|text|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: initials, avatarColor, name, date, text."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
