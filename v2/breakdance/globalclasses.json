  {
    "name": ".progression-list",
    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": "%%SELECTOR%% {\n  display: grid;\n  grid-auto-flow: column;\n  justify-items: start;\n  grid-template-columns: 30px 1fr 30px;\n}\n\n/* counter reset */\n.progression-list {\n  counter-reset: step;\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n/* increment per item */\n.progression-list > li {\n  counter-increment: step;\n  width: 100%;\n}\n\n/* override global summary styles only here */\n.progression-list > li > details > summary {\n  display: grid;\n  grid-template-columns: 30px 1fr 30px;\n  align-items: center;\n  column-gap: 10px;\n  justify-content: unset;\n}\n\n/* left number */\n.progression-list > li > details > summary::before {\n  content: counter(step);\n  display: grid;\n  place-items: center;\n  width: 20px;\n  height: 20px;\n  font-size: 0.875rem;\n  line-height: 1;\n  border-radius: 50%;\n  color: var(--color-card-featured);\n  background-color: var(--color-sage-15);\n}\n\n/* keep right icon aligned */\n.progression-list > li > details > summary::after {\n  justify-self: end;\n}\n",
          "custom_breakpoint_330px": null
        }
      }
    }
  },

