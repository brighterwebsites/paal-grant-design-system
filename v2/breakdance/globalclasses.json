    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": ".faded-line {\n  position: relative;\n  padding-top: 8px;\n}\n\n.faded-line::before {\n  content: \"\";\n  position: absolute;\n  left: 0;\n  right: 0;\n  top: 0;\n  height: 1px;\n  background: linear-gradient(\n    to left,\n    transparent,\n    rgba(255,255,255,0.4),\n    transparent\n  );\n}\n"
        }
      }
