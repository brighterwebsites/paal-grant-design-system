  {
    "name": ".pg-golden--grid",
    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": "%%SELECTOR%% {\n  display: grid;\n  grid-template-columns: repeat(13, 1fr);\n  grid-template-rows: repeat(8, 1fr);\n  gap: 4px;\n  width: 100%;\n  aspect-ratio: 1.618 / 1;\n  box-sizing: border-box;\n}\n\n%%SELECTOR%% * {\n  box-sizing: border-box;\n}\n",
          "breakpoint_tablet_landscape": null,
          "breakpoint_tablet_portrait": null,
          "breakpoint_phone_landscape": "%%SELECTOR%% {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  grid-template-rows: auto;\n  aspect-ratio: 4 / 5;\n  gap: 4px;\n  height: calc(100% / 3);\n}\n\n.pg-golden--hero,\n.pg-golden--secondary,\n.pg-golden--tertiary,\n.pg-golden--icons {\n  grid-column: auto;\n  grid-row: auto;\n}\n\n.pg-golden--hero {\n  grid-column: span 2;\n  grid-row: span 1;\n  position: relative;\n  overflow: hidden;\n  aspect-ratio: unset;\n}\n",
          "breakpoint_phone_portrait": null,
          "custom_breakpoint_330px": "%%SELECTOR%% {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  grid-template-rows: repeat(4, auto);\n  gap: 4px;\n  height: calc(100vw * 2.5);\n}\n\n.pg-golden--hero {\n  grid-column: 1 / 3;\n  grid-row: 1 / 3;\n}\n\n/* Tile 2 — Secondary (5x5)\n   Add class: pg-golden--secondary */\n.pg-golden--secondary {\n  grid-column: 1 / 2;\n  grid-row: 3 / 5;\n}\n\n/* Tile 3 — Tertiary (3x3)\n   Add class: pg-golden--tertiary */\n.pg-golden--tertiary {\n  grid-column: 2 / 3;\n  grid-row: 3 / 5;\n}\n\n.pg-golden--icons {\n  grid-column: 1 / 2;\n  grid-row: 5 / 8;\n}\n\n/* Tile 4 — Icon zone (merged bottom-right 2x3)\n   Add class: pg-golden--icons */\n.pg-golden--icon-box {\n  grid-column: 2 / 3;\n  grid-row: 3 / 4;\n}\n"
        }
      }
    }
  },
  {
    "name": ".pg-golden--icon-box",
    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": "/* Icon box — overlays on top of tile 4\n   Add class: pg-golden--icon-box\n   Place AFTER pg-golden--icons in the parent grid */\n.pg-golden--icon-box {\n  grid-column: 12 / 14;\n  grid-row: 6 / 9;\n  position: relative;\n  z-index: 2;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 12px;\n  pointer-events: none;\n}\n\n/* Make the icons themselves clickable */\n.pg-golden--icon-box a,\n.pg-golden--icon-box button,\n.pg-golden--icon-box .bde-icon {\n  pointer-events: auto;\n}\n\n/* Push icons tile behind */\n.pg-golden--icons {\n  z-index: 1;\n}\n\n",
          "breakpoint_phone_landscape": "\n  .pg-golden--icon-box {\n    grid-column: auto;\n    grid-row: auto;\n    min-height: 220px;\n  }\n\n",
          "breakpoint_phone_portrait": "\n  .pg-golden--icon-box {\n    min-height: 0;\n    aspect-ratio: 1 / 1;\n  }"
        }
      }
    }
  },

