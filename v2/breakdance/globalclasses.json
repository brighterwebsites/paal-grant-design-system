          "breakpoint_base": ".pg-stack-wrapper {\n  display: block !important;\n  position: relative !important;\n  width: 100%;\n}\n\n.pg-stack-panel {\n  position: sticky !important;\n  top: 0 !important;\n  height: 100vh !important;\n  overflow: hidden !important;\n}\n\n.pg-stack-panel:nth-child(1) { z-index: 3; }\n.pg-stack-panel:nth-child(2) { z-index: 2; }\n.pg-stack-panel:nth-child(3) { z-index: 1; }\n"
        }
      }
    }
