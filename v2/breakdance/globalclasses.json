          "breakpoint_base": ".pg_hover_reveal-up .bde-text {\n  max-height: 0;\n  overflow: hidden;\n  opacity: 0;\n  transition:\n    opacity 0.2s,\n    max-height 0.2s;\n}\n\n.pg_hover_reveal-up:hover .bde-text,\n.pg_hover_reveal-up:focus-within .bde-text {\n  opacity: 1;\n  max-height: 100vh;\n  transition:\n    opacity 0.8s ease-in-out,\n    max-height 0.8s ease-in-out;\n}\n"
        }
