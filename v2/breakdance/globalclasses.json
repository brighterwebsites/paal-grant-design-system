  {
    "name": ".pg_hover_reveal-up",
    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": ".pg_hover_reveal-up .bde-text {\n  max-height: 0;\n  overflow: hidden;\n  opacity: 0;\n  transition:\n    opacity 0.2s,\n    max-height 0.2s;\n}\n\n.pg_hover_reveal-up:hover .bde-text,\n.pg_hover_reveal-up:focus-within .bde-text {\n  opacity: 1;\n  max-height: 100vh;\n  transition:\n    opacity 0.8s ease-in-out,\n    max-height 0.8s ease-in-out;\n}\n"
        }
      }
    }
  },
  {
    "name": ".pg-hover-reveal--grid",
    "type": "class",
    "properties": {
      "custom_css": {
        "css": {
          "breakpoint_base": "%%SELECTOR%% {\n  grid-gap: 3px;\n}\n%%SELECTOR%% > div {\n  min-height: 15rem;\n}\n%%SELECTOR%% .bde-heading, %%SELECTOR%% .bde-text {\n  transition: 0.4s;\n}\n\n%%SELECTOR%% .bde-text {\n  max-height: 0;\n  overflow: hidden;\n  transition: 0.2s;\n  opacity: 0;\n}\n%%SELECTOR%% > div:hover .bde-text,\n%%SELECTOR%% > div:focus-within .bde-text {\n  opacity: 1;\n  max-height: 100vh;\n  transition: 0.8s ease-in-out;\n}"
        }
      }
    }
  },
